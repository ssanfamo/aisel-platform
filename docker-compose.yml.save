version: "3.8"

services:
  api:
    build: ./apps/api
    container_name: aisel-api
    ports:
      - "8000:8000"

  web:
    build: ./apps/web
    container_name: aisel-web
    ports:
      - "3000:3000"
    depends_on:
      - api

    environment:
      - RESEND_API_KEY=re_UMSsqhur_KzsdwAQnjdbHZ1MQfAEqwTUw
